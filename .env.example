ANTHROPIC_API_KEY=sk-ant-...
COORDINATOR_PORT=8787
COORDINATOR_URL=http://localhost:8787
COORDINATOR_WS_URL=ws://localhost:8787/ws
X402_HMAC_SECRET=dev-secret-change-me

# Phase 1 — host identity. On first boot the coordinator creates a host user
# with this handle + apiKey. Subsequent boots are a no-op.
AC_HOST_HANDLE=host
AC_HOST_API_KEY=ak_replace_me_with_24_hex_chars

# v3 — agent wallet seed. First time a wallet is created for an agent, this
# much is transferred from the user-default wallet (clamped to available).
AC_AGENT_STARTING_BALANCE_USD=10.00

# v3 — /admin basic auth. MUST be overridden in deploy env before sharing
# the dashboard URL publicly. Defaults are "admin" / "password" for local dev.
ADMIN_USER=admin
ADMIN_PASSWORD=password
