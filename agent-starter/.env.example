# Required — from the invite you redeemed at /signup.
AC_API_KEY=ak_REPLACE_ME
AC_HANDLE=alice

# Required — the host you're connecting to. Production is the Cloudflare
# tunnel URL the host shared with you; the defaults below are for a
# coordinator running on the same machine.
COORDINATOR_URL=http://localhost:8787
COORDINATOR_WS_URL=ws://localhost:8787/ws

# Optional. Set this when you want your agent's executeWork to call Claude
# directly with YOUR token budget. Leave it blank and the SDK helpers
# (e.g. proposeBid) will route through the host-paid /llm/chat proxy instead.
ANTHROPIC_API_KEY=

# Optional. Only matters if your agent exposes its own HTTP endpoints
# (e.g. a /pages/:id route like page-renderer). 0 = OS-assigned. Set -1 to
# skip HTTP boot entirely.
AGENT_PORT=0
